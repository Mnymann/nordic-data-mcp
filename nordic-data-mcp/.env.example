# --- Required ---
# Your Nordic Data API key. Get one at https://addonnordic.dk
NORDIC_API_KEY=your_key_here

# --- Hosts: choose ONE of the two setups below ---

# Setup A — single host (default if neither A nor B is set):
# NORDIC_API_BASE_URL=https://api.addonnordic.dk

# Setup B — failover between two hosts:
# Primary is tried first. If primary returns a network error, a 5xx, or 429,
# the request is retried once on the fallback host. Errors are logged to stderr.
# NORDIC_API_PRIMARY=https://your-railway-host.example
# NORDIC_API_FALLBACK=https://your-render-host.example

# --- HTTP transport only ---
PORT=3000
